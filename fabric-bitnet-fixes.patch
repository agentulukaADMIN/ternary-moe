                 # The scale is inverted
                 return data / scale.float()
 
@@ -3513,7 +3520,15 @@ class BitnetModel(TextModel):
                 packed = data_torch.to(torch.uint8)
                 unpacked = self._unpack_bitnet_weights(packed)
                 scale_value = scale_tensor.reshape(-1)[0].item()
-                data_torch = unpacked * scale_value
+                # AutoBitLinear ("autobitlinear") multiplies its output by
+                # weight_scale; the packed BitLinear divides (inverted scale).
+                # See dequant_bitnet() above, which normally handles this
+                # before tensors ever reach modify_tensors.
+                lc = (self.hparams.get("quantization_config") or {}).get("linear_class")
+                if lc == "autobitlinear":
+                    data_torch = unpacked * scale_value
